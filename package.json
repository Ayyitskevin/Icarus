{
  "name": "icarus",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first, guarded AI software factory",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22.23.0 <23",
    "pnpm": ">=9.15.0 <10"
  },
  "scripts": {
    "build": "pnpm build:node && pnpm --filter @icarus/workspace build",
    "build:node": "tsc -b --pretty false",
    "icarus": "pnpm --filter @icarus/cli start",
    "workspace:start": "pnpm build && pnpm --filter @icarus/api start",
    "workspace:ui": "pnpm --filter @icarus/workspace dev",
    "smoke:workspace": "pnpm build && node scripts/smoke-workspace.mjs",
    "smoke:workspace:browser": "pnpm build && node scripts/smoke-workspace-browser.mjs",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "typecheck": "pnpm typecheck:node && pnpm --filter @icarus/workspace typecheck",
    "typecheck:node": "tsc -b --pretty false",
    "test": "vitest run tests/unit tests/provider",
    "test:integration": "pnpm build && vitest run tests/integration",
    "eval": "pnpm build && node scripts/eval-fixtures.mjs",
    "security": "vitest run tests/security && node scripts/security-check.mjs",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm test:integration && pnpm eval && pnpm security && pnpm build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "22.20.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
